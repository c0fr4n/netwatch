# ──────────────────────────────────────────────
# NetWatch — Variables de entorno
# ──────────────────────────────────────────────

# Puerto del servidor web (default: 3000)
PORT=3000

# Redis (para persistencia de alertas y estados)
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────
# Servidor BOSQUE (MagicINFO)
# ──────────────────────────────────────────────
BOSQUE_URL=https://bosque.arcoprime.cl:7020/MagicInfo
BOSQUE_USER=admin
BOSQUE_PASS=tu_contraseña

# Webhook Google Chat para alertas Bosque
# (si omites BOSQUE_WEBHOOK usa GOOGLE_SPACES_WEBHOOK como fallback)
BOSQUE_WEBHOOK=https://chat.googleapis.com/v1/spaces/XXXX/messages?key=YYYY&token=ZZZZ

# ──────────────────────────────────────────────
# Servidor CALLECALLE (MagicINFO)
# ──────────────────────────────────────────────
CALLECALLE_URL=https://callecalle.arcoprime.cl:7020/MagicInfo
CALLECALLE_USER=admin
CALLECALLE_PASS=tu_contraseña

# Webhook Google Chat para alertas Callecalle
CALLECALLE_WEBHOOK=https://chat.googleapis.com/v1/spaces/XXXX/messages?key=YYYY&token=ZZZZ

# ──────────────────────────────────────────────
# Webhook compartido (fallback si no defines los anteriores)
# ──────────────────────────────────────────────
# GOOGLE_SPACES_WEBHOOK=https://chat.googleapis.com/v1/spaces/XXXX/messages?key=YYYY&token=ZZZZ

# ──────────────────────────────────────────────
# Solo para monitor.js en modo standalone
# ──────────────────────────────────────────────
# Intervalo en segundos (ej: 300 = 5 minutos)
# MONITOR_INTERVAL=300
